-- Active theme (mutable copy)
local T = {}
for k, v in pairs(Themes.Cynnet) do T[k] = v end

-- Registry of themed elements for live re-theming
-- Each entry: { instance, property, themeKey }
local ThemeRegistry = {}

local function RegisterTheme(instance, property, themeKey)
    table.insert(ThemeRegistry, { inst = instance, prop = property, key = themeKey })
end

-- Forward-declared so ApplyTheme can call it; assigned inside CreateWindow
local _onThemeApplied = nil

local function ApplyTheme(themeName)
    local theme = Themes[themeName]
    if not theme then return end
    -- Update T immediately so all future creates use new colors
    for k, v in pairs(theme) do T[k] = v end
    -- Instantly apply to every registered element (no tweens = no desync)
    -- Iterate backwards so dead entries can be safely removed
    for i = #ThemeRegistry, 1, -1 do
        local entry = ThemeRegistry[i]
        local ok = pcall(function()
            if entry.inst and entry.inst.Parent then
                entry.inst[entry.prop] = T[entry.key]
            end
        end)
        if not ok then table.remove(ThemeRegistry, i) end
    end
    -- Notify window to re-stamp tab button colours (managed outside registry)
    if _onThemeApplied then _onThemeApplied() end
end


