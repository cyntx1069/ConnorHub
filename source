        Position = UDim2.new(0.5,0,0,0),
        AnchorPoint = Vector2.new(0.5,0),
        BackgroundColor3 = T.Accent, Parent = Card,
    })
    Round(TopLine, 2); GradientStripe(TopLine)

    local LogoDot = Frame({
        Size = UDim2.new(0,14,0,14),
        Position = UDim2.new(0.5,-7,0,30),
        BackgroundColor3 = T.Accent, Parent = Card,
    })
    Round(LogoDot, 7)

    local TitleLbl = Label({
        Text = "CONNOR", Font = Enum.Font.GothamBold, TextSize = 28,
        TextColor3 = T.TextPrimary, TextTransparency = 1,
        Size = UDim2.new(1,0,0,36), Position = UDim2.new(0,0,0,52),
        TextXAlignment = Enum.TextXAlignment.Center, Parent = Card,
    })
    local AccentWord = Label({
        Text = "HUB", Font = Enum.Font.GothamBold, TextSize = 28,
        TextColor3 = T.Accent, TextTransparency = 1,
        Size = UDim2.new(1,0,0,36), Position = UDim2.new(0,0,0,80),
        TextXAlignment = Enum.TextXAlignment.Center, Parent = Card,
    })
    local SubLbl = Label({
        Text = "Universal Utility Tool  ·  v3.0",
        Font = Enum.Font.Gotham, TextSize = 11,
        TextColor3 = T.TextMuted, TextTransparency = 1,
        Size = UDim2.new(1,0,0,20), Position = UDim2.new(0,0,0,118),
        TextXAlignment = Enum.TextXAlignment.Center, Parent = Card,
    })

    local BarTrack = Frame({
        Size = UDim2.new(0,200,0,3),
        Position = UDim2.new(0.5,-100,1,-20),
        BackgroundColor3 = T.BorderDim, Parent = Card,
    })
    Round(BarTrack, 2)
    local BarFill = Frame({ Size = UDim2.new(0,0,1,0), BackgroundColor3 = T.Accent, Parent = BarTrack })
    Round(BarFill, 2); GradientStripe(BarFill)

    -- Animate IN
    Tw(BG,   { BackgroundTransparency = 0.10 }, TI.Intro)
    Tw(blur, { Size = 24 }, TI.Intro)
    task.wait(0.15)
    Tw(Card, { BackgroundTransparency = 0 }, TI.Med)
    task.wait(0.10)
    Tw(TopLine, { Size = UDim2.new(1,0,0,2) }, TI.Med)
    task.wait(0.10)
    Tw(LogoDot, { BackgroundColor3 = T.AccentBright }, TI.Fast)
    task.wait(0.08)
    Tw(LogoDot, { BackgroundColor3 = T.Accent }, TI.Med)
    Tw(TitleLbl, { TextTransparency = 0 }, TI.Med)
    task.wait(0.10)
    Tw(AccentWord, { TextTransparency = 0 }, TI.Med)
    task.wait(0.08)
    Tw(SubLbl, { TextTransparency = 0 }, TI.Med)
    task.wait(0.15)
    Tw(BarFill, { Size = UDim2.new(1,0,1,0) },
        TweenInfo.new(0.9, Enum.EasingStyle.Quint, Enum.EasingDirection.Out))
    task.wait(1.05)

    -- Animate OUT
    Tw(TitleLbl,   { TextTransparency = 1 }, TI.Med)
    Tw(AccentWord, { TextTransparency = 1 }, TI.Med)
    Tw(SubLbl,     { TextTransparency = 1 }, TI.Med)
    task.wait(0.08)
    Tw(Card, { BackgroundTransparency = 1 }, TI.Med)
    task.wait(0.05)
    Tw(blur, { Size = 0 }, TI.Slow)
    Tw(BG,   { BackgroundTransparency = 1 }, TI.Slow)
    task.wait(0.50)

    blur:Destroy(); Gui:Destroy()
    if onComplete then onComplete() end
end

