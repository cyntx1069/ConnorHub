--  ✦  WATERMARK  (draggable top-right HUD) — FIXED
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local function CreateWatermark(screenGui)
    local displayName = LocalPlayer.DisplayName

    local WM = Frame({
        Name             = "Watermark",
        Size             = UDim2.new(0, 10, 0, 30),
        AutomaticSize    = Enum.AutomaticSize.X,
        -- Start with AnchorPoint 0,0 from the very beginning to avoid snap issues
        Position         = UDim2.new(1, -16, 0, 14),
        AnchorPoint      = Vector2.new(1, 0),
        BackgroundColor3 = T.Surface,
        BackgroundTransparency = 1,
        ZIndex           = 100,
        Parent           = screenGui,
    })
    Round(WM, 8)
    local wmBorderStroke = Stroke(WM, T.Border, 1)
    Pad(WM, 0, 0, 12, 12)
    RegisterTheme(WM, "BackgroundColor3", "Surface")
    RegisterTheme(wmBorderStroke, "Color", "Border")

    local wmStripe = Frame({
        Size = UDim2.new(1,0,0,2), BackgroundColor3 = T.Accent, ZIndex = 101, Parent = WM,
    })
    Round(wmStripe, 2)
    RegisterTheme(wmStripe, "BackgroundColor3", "Accent")

    local WMText = Label({
        Text = "", Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = T.TextPrimary,
        Size = UDim2.new(1, 0, 1, 0), TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = 101, Parent = WM,
    })
    RegisterTheme(WMText, "TextColor3", "TextPrimary")

    local fps, fpsAccum, fpsCount = 60, 0, 0
    local ping, pingTimer = 0, 0

    RunService.RenderStepped:Connect(function(dt)
        fpsAccum = fpsAccum + dt; fpsCount = fpsCount + 1
        if fpsAccum >= 0.5 then
            fps = math.floor(fpsCount / fpsAccum); fpsAccum = 0; fpsCount = 0
        end
        pingTimer = pingTimer + dt
        if pingTimer >= 2 then
            pingTimer = 0
            pcall(function()
                ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            end)
        end
        WMText.Text = string.format(
            "ConnorHub  |  %s  |  %d FPS  |  %d ms  |  %s",
            displayName, fps, ping, ExecutorName
        )
    end)

    -- ── FIXED Drag ─────────────────────────────────
    -- We always keep AnchorPoint at 0,0 during drag.
    -- We convert the initial AnchorPoint(1,0) position to AnchorPoint(0,0) once,
    -- then never change AnchorPoint again — eliminating the offset jump entirely.
    local dragging = false
    local dragStartMouse = Vector2.new()
    local dragStartPos   = Vector2.new()

    local DragBtn = Instance.new("TextButton")
    DragBtn.Size = UDim2.new(1,0,1,0); DragBtn.Text = ""
    DragBtn.BackgroundTransparency = 1; DragBtn.ZIndex = 110; DragBtn.Parent = WM

    DragBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Capture absolute pixel position of the top-left corner BEFORE any anchor changes
            local absX = WM.AbsolutePosition.X
            local absY = WM.AbsolutePosition.Y
            -- Now permanently switch to AnchorPoint(0,0) so future drags are simple
            WM.AnchorPoint = Vector2.new(0, 0)
            WM.Position    = UDim2.new(0, absX, 0, absY)
            -- Record drag start state
            dragStartMouse = Vector2.new(inp.Position.X, inp.Position.Y)
            dragStartPos   = Vector2.new(absX, absY)
            dragging = true
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local dx = inp.Position.X - dragStartMouse.X
            local dy = inp.Position.Y - dragStartMouse.Y
            WM.Position = UDim2.new(0, dragStartPos.X + dx, 0, dragStartPos.Y + dy)
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Slide-in entrance (starts from AnchorPoint 1,0 temporarily for the animation only)
    WM.Position = UDim2.new(1, 40, 0, 14)
    task.wait(0.05)
    Tw(WM, { BackgroundTransparency = 0 }, TI.Med)
    Tw(WM, { Position = UDim2.new(1, -16, 0, 14) }, TI.Spring)
end

