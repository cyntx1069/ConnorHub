  ── HOW TO USE ──────────────────────────────────────────

  -- Step 1: Load the library via loadstring
  local Library = loadstring(game:HttpGet(
      "https://raw.githubusercontent.com/YourName/ConnorHub/main/source.lua"
  ))()

  -- Step 2: Create a Window
  local Window = Library:CreateWindow({
      Title   = "My Hub",
      SubTitle = "v1.0",
  })

  -- Step 3: Create Tabs
  local MainTab = Window:CreateTab({ Name = "Main", Icon = "⚡" })
  local PlayerTab = Window:CreateTab({ Name = "Player", Icon = "👤" })

  -- Step 4: Add Elements to Tabs
  MainTab:AddSection("Speed")
  MainTab:AddSlider({
      Name     = "Walk Speed",
      Min      = 8,
      Max      = 500,
      Default  = 16,
      Callback = function(v)
          local char = game.Players.LocalPlayer.Character
          if char then
              local hum = char:FindFirstChildOfClass("Humanoid")
              if hum then hum.WalkSpeed = v end
          end
      end,
  })

  MainTab:AddButton({
      Name     = "Reset Character",
      Style    = "danger",
      Callback = function()
          local char = game.Players.LocalPlayer.Character
          if char then
              local hum = char:FindFirstChildOfClass("Humanoid")
              if hum then hum.Health = 0 end
          end
      end,
  })

  -- All available element methods:
  -- Tab:AddSection(name)
  -- Tab:AddLabel({ Name, Value, Color })
  -- Tab:AddButton({ Name, Style, Callback })      Style = "primary"|"secondary"|"danger"|"success"
  -- Tab:AddToggle({ Name, Default, Callback })
