--  ✦  WATERMARK  (draggable top-right HUD)
--     ConnorHub  |  DisplayName  |  FPS  |  Ping  |  Executor
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local function CreateWatermark(screenGui)
    local displayName = LocalPlayer.DisplayName

    -- Container
    local WM = Frame({
        Name             = "Watermark",
        Size             = UDim2.new(0, 10, 0, 30),
        AutomaticSize    = Enum.AutomaticSize.X,
        Position         = UDim2.new(1, -16, 0, 14),
        AnchorPoint      = Vector2.new(1, 0),
        BackgroundColor3 = T.Surface,
        BackgroundTransparency = 1,
        ZIndex           = 100,
        Parent           = screenGui,
    })
    Round(WM, 8)
    Stroke(WM, T.Border, 1)
    Pad(WM, 0, 0, 12, 12)

    -- Top accent stripe
    local wmStripe = Frame({
        Size = UDim2.new(1,0,0,2),
        BackgroundColor3 = T.Accent,
        ZIndex = 101, Parent = WM,
    })
    Round(wmStripe, 2)
    GradientStripe(wmStripe)

    -- Single text label (auto-sized, updated each frame)
    local WMText = Label({
        Text           = "",
        Font           = Enum.Font.Gotham,
        TextSize       = 12,
        TextColor3     = T.TextPrimary,
        Size           = UDim2.new(1, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex         = 101,
        Parent         = WM,
    })

    -- ── Live stats ─────────────────────────────
    local fps, fpsAccum, fpsCount = 60, 0, 0
    local ping, pingTimer = 0, 0

    RunService.RenderStepped:Connect(function(dt)
        fpsAccum = fpsAccum + dt
        fpsCount = fpsCount + 1
        if fpsAccum >= 0.5 then
            fps      = math.floor(fpsCount / fpsAccum)
            fpsAccum = 0; fpsCount = 0
        end

        pingTimer = pingTimer + dt
        if pingTimer >= 2 then
            pingTimer = 0
            pcall(function()
                ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            end)
        end

        WMText.Text = string.format(
            "ConnorHub  |  %s  |  %d FPS  |  %d ms  |  %s",
            displayName, fps, ping, ExecutorName
        )
    end)

    -- ── Drag ───────────────────────────────────
    local dragging, dragStart, startPos
    local DragBtn = Instance.new("TextButton")
    DragBtn.Size = UDim2.new(1,0,1,0); DragBtn.Text = ""
    DragBtn.BackgroundTransparency = 1; DragBtn.ZIndex = 110
    DragBtn.Parent = WM

    DragBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = inp.Position
            -- Snap AnchorPoint to 0,0 and record absolute pixel position
            WM.AnchorPoint = Vector2.new(0, 0)
            startPos = UDim2.new(0, WM.AbsolutePosition.X, 0, WM.AbsolutePosition.Y)
            WM.Position = startPos
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - dragStart
            WM.Position = UDim2.new(
                0, startPos.X.Offset + d.X,
                0, startPos.Y.Offset + d.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Slide-in entrance animation
    WM.Position = UDim2.new(1, 40, 0, 14)
    task.wait(0.05)
    Tw(WM, { BackgroundTransparency = 0 }, TI.Med)
    Tw(WM, { Position = UDim2.new(1, -16, 0, 14) }, TI.Spring)
end

