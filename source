function Library:CreateWindow(config)
    config = config or {}
    local Title   = config.Title    or "ConnorHub"
    local SubTitle= config.SubTitle or "v3.0"
    local WinSize = config.Size     or Vector2.new(600, 460)

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name           = "ConnorHub"
    ScreenGui.ResetOnSpawn   = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.Parent         = LocalPlayer:WaitForChild("PlayerGui")

    -- ── Main window ────────────────────────────
    local Win = Frame({
        Name             = "Window",
        Size             = UDim2.new(0, WinSize.X, 0, 0),
        Position         = UDim2.new(0.5, -WinSize.X/2, 0.5, -WinSize.Y/2),
        BackgroundColor3 = T.BG,
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent           = ScreenGui,
    })
    Round(Win, 14); Stroke(Win, T.Border, 1)

    local Stripe = Frame({ Size=UDim2.new(1,0,0,2), BackgroundColor3=T.Accent, ZIndex=5, Parent=Win })
    Round(Stripe, 2); GradientStripe(Stripe)

    -- ── Title bar ──────────────────────────────
    local TBar = Frame({ Size=UDim2.new(1,0,0,52), BackgroundColor3=T.Surface, Parent=Win })
    Frame({ Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1), BackgroundColor3=T.Border, Parent=TBar })

    local Dot = Frame({ Size=UDim2.new(0,10,0,10), Position=UDim2.new(0,16,0.5,-5), BackgroundColor3=T.Accent, Parent=TBar })
    Round(Dot, 5)
    Frame({ Size=UDim2.new(0,22,0,22), Position=UDim2.new(0,10,0.5,-11), BackgroundColor3=T.Accent, BackgroundTransparency=0.72, ZIndex=Dot.ZIndex-1, Parent=TBar })

    Label({ Text=Title:upper(), Font=Enum.Font.GothamBold, TextSize=14, TextColor3=T.TextPrimary,
        TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(0,140,1,0), Position=UDim2.new(0,34,0,0), Parent=TBar })
    Label({ Text=SubTitle, Font=Enum.Font.Gotham, TextSize=11, TextColor3=T.TextSecondary,
        TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(0,60,1,0), Position=UDim2.new(0,130,0,0), Parent=TBar })

    local function WinBtn(lbl, xOff)
        local b = Instance.new("TextButton")
        b.Text=lbl; b.Font=Enum.Font.GothamBold; b.TextSize=12
        b.TextColor3=T.TextSecondary; b.Size=UDim2.new(0,30,0,30)
        b.Position=UDim2.new(1,xOff,0.5,-15); b.BackgroundColor3=T.SurfaceAlt
        b.BorderSizePixel=0; b.Parent=TBar; Round(b,7)
        return b
    end

    local CloseBtn = WinBtn("✕", -42)
    local MinBtn   = WinBtn("─", -78)

    CloseBtn.MouseEnter:Connect(function() Tw(CloseBtn,{BackgroundColor3=T.Danger,TextColor3=T.White}) end)
    CloseBtn.MouseLeave:Connect(function() Tw(CloseBtn,{BackgroundColor3=T.SurfaceAlt,TextColor3=T.TextSecondary}) end)
    CloseBtn.MouseButton1Click:Connect(function()
        Tw(Win,{Size=UDim2.new(0,WinSize.X,0,0),BackgroundTransparency=1},TI.Med)
        task.delay(0.32, function() ScreenGui:Destroy() end)
    end)

    local minimised = false
    MinBtn.MouseEnter:Connect(function() Tw(MinBtn,{BackgroundColor3=T.AccentDim,TextColor3=T.Accent}) end)
    MinBtn.MouseLeave:Connect(function() Tw(MinBtn,{BackgroundColor3=T.SurfaceAlt,TextColor3=T.TextSecondary}) end)
    MinBtn.MouseButton1Click:Connect(function()
        minimised = not minimised
        if minimised then
            Tw(Win,{Size=UDim2.new(0,WinSize.X,0,52)},TI.Med)
        else
            Tw(Win,{Size=UDim2.new(0,WinSize.X,0,WinSize.Y)},TI.Spring)
        end
    end)

    -- Draggable title bar
    do
        local drag, dStart, sPos
        TBar.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                drag=true; dStart=inp.Position; sPos=Win.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if drag and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local d = inp.Position - dStart
                Win.Position = UDim2.new(sPos.X.Scale,sPos.X.Offset+d.X,sPos.Y.Scale,sPos.Y.Offset+d.Y)
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
        end)
    end

    -- ── Sidebar ────────────────────────────────
    local Sidebar = Frame({ Size=UDim2.new(0,148,1,-52), Position=UDim2.new(0,0,0,52), BackgroundColor3=T.Surface, Parent=Win })
    Frame({ Size=UDim2.new(0,1,1,0), Position=UDim2.new(1,-1,0,0), BackgroundColor3=T.Border, Parent=Sidebar })

    local TabScroll = Instance.new("ScrollingFrame")
    TabScroll.Size=UDim2.new(1,0,1,0); TabScroll.BackgroundTransparency=1; TabScroll.ScrollBarThickness=0; TabScroll.Parent=Sidebar
    Pad(TabScroll,10,10,8,8)
    local TabList = ListLayout(TabScroll,Enum.FillDirection.Vertical,4)
    TabList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        TabScroll.CanvasSize=UDim2.new(0,0,0,TabList.AbsoluteContentSize.Y+20)
    end)

    local Indicator = Frame({ Size=UDim2.new(0,3,0,34), Position=UDim2.new(0,0,0,10), BackgroundColor3=T.Accent, ZIndex=10, Parent=Sidebar })
    Round(Indicator, 2)

    -- ── Content area ───────────────────────────
    local ContentArea = Frame({ Size=UDim2.new(1,-148,1,-52), Position=UDim2.new(0,148,0,52), BackgroundColor3=T.BG, ClipsDescendants=true, Parent=Win })

    -- ── Tab system ─────────────────────────────
    local AllTabs  = {}
    local ActiveTab = nil

    local function SetActive(tab)
        if ActiveTab == tab then return end
        ActiveTab = tab
        for _, t in pairs(AllTabs) do
            local on = (t == tab)
            Tw(t._btn,   {BackgroundColor3 = on and T.AccentDim or T.Surface, BackgroundTransparency = on and 0 or 1})
            Tw(t._icon,  {TextColor3 = on and T.Accent or T.TextDim})
            Tw(t._label, {TextColor3 = on and T.TextPrimary or T.TextSecondary})
            t._page.Visible = on
            if on then
                local py = t._btn.AbsolutePosition.Y - Sidebar.AbsolutePosition.Y
                Tw(Indicator,{Position=UDim2.new(0,0,0,py+1)},TI.Med)
                t._page.Position = UDim2.new(0.04,0,0,0)
                Tw(t._page,{Position=UDim2.new(0,0,0,0)},TI.Med)
            end
        end
    end

    local WindowObj = {}

    -- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    --  Window:CreateTab
    -- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    function WindowObj:CreateTab(cfg)
        cfg = cfg or {}
        local name = cfg.Name or "Tab"
        local icon = cfg.Icon or "*"

        local Btn = Instance.new("TextButton")
        Btn.Size=UDim2.new(1,0,0,34); Btn.BackgroundColor3=T.AccentDim
        Btn.BackgroundTransparency=1; Btn.BorderSizePixel=0; Btn.Text=""
        Btn.Parent=TabScroll; Round(Btn,8)

        local BtnIcon  = Label({ Text=icon, Font=Enum.Font.Gotham, TextSize=14, TextColor3=T.TextDim,
            Size=UDim2.new(0,28,1,0), Position=UDim2.new(0,8,0,0), Parent=Btn })
        local BtnLabel = Label({ Text=name, Font=Enum.Font.Gotham, TextSize=12, TextColor3=T.TextSecondary,
            TextXAlignment=Enum.TextXAlignment.Left,
            Size=UDim2.new(1,-40,1,0), Position=UDim2.new(0,36,0,0), Parent=Btn })

        local Page = Instance.new("ScrollingFrame")
        Page.Size=UDim2.new(1,0,1,0); Page.BackgroundColor3=T.BG; Page.BackgroundTransparency=0
        Page.BorderSizePixel=0; Page.ScrollBarThickness=3
        Page.ScrollBarImageColor3=T.Accent; Page.ScrollBarImageTransparency=0.4
        Page.Visible=false; Page.Parent=ContentArea
        Pad(Page,14,14,16,16)
        local PageList = ListLayout(Page,Enum.FillDirection.Vertical,8)
        AutoCanvas(Page,PageList)

        local tab = {_btn=Btn,_icon=BtnIcon,_label=BtnLabel,_page=Page,_list=PageList}

        Btn.MouseEnter:Connect(function()
            if ActiveTab~=tab then Tw(Btn,{BackgroundTransparency=0.7,BackgroundColor3=T.SurfaceAlt}) end
        end)
        Btn.MouseLeave:Connect(function()
            if ActiveTab~=tab then Tw(Btn,{BackgroundTransparency=1}) end
        end)
        Btn.MouseButton1Click:Connect(function() SetActive(tab) end)

        table.insert(AllTabs,tab)
        if #AllTabs==1 then task.defer(function() SetActive(tab) end) end

        -- ── Element builders ───────────────────
        local Tab = {}

        function Tab:AddSection(title)
            local w = Frame({Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,Parent=Page})
            Frame({Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0.5,0),BackgroundColor3=T.BorderDim,Parent=w})
            Label({Text="  "..title:upper().."  ",Font=Enum.Font.GothamBold,TextSize=9,
                TextColor3=T.TextMuted,BackgroundColor3=T.BG,
                Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,ZIndex=2,Parent=w})
        end

        function Tab:AddSeparator()
            Frame({Size=UDim2.new(1,0,0,1),BackgroundColor3=T.BorderDim,Parent=Page})
        end

        function Tab:AddLabel(cfg)
            cfg=cfg or {}
            local row=Frame({Size=UDim2.new(1,0,0,38),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(row,8); Stroke(row,T.BorderDim,1); Pad(row,0,0,14,14)
            Label({Text=cfg.Name or "Label",Font=Enum.Font.Gotham,TextSize=12,
                TextColor3=T.TextSecondary,TextXAlignment=Enum.TextXAlignment.Left,
                Size=UDim2.new(0.55,0,1,0),Parent=row})
            local vl=Label({Text=tostring(cfg.Value or "--"),Font=Enum.Font.Code,TextSize=12,
                TextColor3=cfg.Color or T.Accent,TextXAlignment=Enum.TextXAlignment.Right,
                Size=UDim2.new(0.45,0,1,0),Position=UDim2.new(0.55,0,0,0),Parent=row})
            return {Set=function(v) vl.Text=tostring(v) end, SetColor=function(c) vl.TextColor3=c end}
        end

        function Tab:AddBadge(cfg)
            cfg=cfg or {}
            local cm={accent=T.Accent,success=T.Success,warning=T.Warning,danger=T.Danger}
            local bc=cm[cfg.Color or "accent"] or T.Accent
            local row=Frame({Size=UDim2.new(1,0,0,38),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(row,8); Stroke(row,T.BorderDim,1); Pad(row,0,0,14,14)
            Label({Text=cfg.Name or "Badge",Font=Enum.Font.Gotham,TextSize=12,
                TextColor3=T.TextSecondary,TextXAlignment=Enum.TextXAlignment.Left,
                Size=UDim2.new(0.6,0,1,0),Parent=row})
            local bf=Frame({Size=UDim2.new(0,0,0,20),AutomaticSize=Enum.AutomaticSize.X,
                Position=UDim2.new(1,-2,0.5,-10),AnchorPoint=Vector2.new(1,0),
                BackgroundColor3=bc,Parent=row})
            Round(bf,10); Pad(bf,0,0,9,9)
            Label({Text=tostring(cfg.Badge or ""),Font=Enum.Font.GothamBold,TextSize=10,
                TextColor3=T.White,Size=UDim2.new(1,0,1,0),Parent=bf})
        end

        function Tab:AddButton(cfg)
            cfg=cfg or {}
            local bgMap={primary=T.Accent,secondary=T.SurfaceAlt,danger=T.Danger,success=T.Success}
            local bg=bgMap[cfg.Style or "primary"] or T.Accent
            local tc=(cfg.Style=="secondary") and T.TextPrimary or T.White
            local btn=Instance.new("TextButton")
            btn.Text=cfg.Name or "Button"; btn.Font=Enum.Font.GothamBold; btn.TextSize=12
            btn.TextColor3=tc; btn.Size=UDim2.new(1,0,0,38)
            btn.BackgroundColor3=bg; btn.BorderSizePixel=0; btn.Parent=Page
            Round(btn,8)
            if cfg.Style=="secondary" then Stroke(btn,T.Border,1) end
            local function B(c) return Color3.new(math.min(c.R+0.09,1),math.min(c.G+0.09,1),math.min(c.B+0.09,1)) end
            btn.MouseButton1Down:Connect(function() Tw(btn,{Size=UDim2.new(0.98,0,0,34),Position=UDim2.new(0.01,0,0,2)},TI.Fast) end)
            btn.MouseButton1Up:Connect(function()
                Tw(btn,{Size=UDim2.new(1,0,0,38),Position=UDim2.new(0,0,0,0),BackgroundColor3=bg},TI.Fast)
                if cfg.Callback then task.spawn(cfg.Callback) end
            end)
            btn.MouseEnter:Connect(function() Tw(btn,{BackgroundColor3=B(bg)},TI.Fast) end)
            btn.MouseLeave:Connect(function() Tw(btn,{BackgroundColor3=bg},TI.Fast) end)
            return btn
        end

        function Tab:AddToggle(cfg)
            cfg=cfg or {}
            local state=cfg.Default or false
            local row=Frame({Size=UDim2.new(1,0,0,44),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(row,8); Stroke(row,T.BorderDim,1); Pad(row,0,0,14,14)
            Label({Text=cfg.Name or "Toggle",Font=Enum.Font.Gotham,TextSize=12,
                TextColor3=T.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,
                Size=UDim2.new(0.68,0,1,0),Parent=row})
            local track=Frame({Size=UDim2.new(0,44,0,24),Position=UDim2.new(1,-44,0.5,-12),
                BackgroundColor3=state and T.Accent or T.BorderDim,Parent=row})
            Round(track,12)
            local thumb=Frame({Size=UDim2.new(0,18,0,18),
                Position=state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9),
                BackgroundColor3=T.White,ZIndex=2,Parent=track})
            Round(thumb,9)
            local cb=Instance.new("TextButton")
            cb.Size=UDim2.new(1,0,1,0); cb.Text=""; cb.BackgroundTransparency=1; cb.ZIndex=5; cb.Parent=row
            local function Refresh()
                Tw(thumb,{Position=state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)},TI.Med)
                Tw(track,{BackgroundColor3=state and T.Accent or T.BorderDim},TI.Med)
            end
            cb.MouseButton1Click:Connect(function()
                state=not state; Refresh()
                if cfg.Callback then task.spawn(cfg.Callback,state) end
            end)
            return {Get=function() return state end, Set=function(v) state=v; Refresh() end}
        end

        function Tab:AddSlider(cfg)
            cfg=cfg or {}
            local mn=cfg.Min or 0; local mx=cfg.Max or 100
            local val=math.clamp(cfg.Default or mn,mn,mx)
            local wrap=Frame({Size=UDim2.new(1,0,0,58),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(wrap,8); Stroke(wrap,T.BorderDim,1); Pad(wrap,8,8,14,14)
            local top=Frame({Size=UDim2.new(1,0,0,20),BackgroundTransparency=1,Parent=wrap})
            Label({Text=cfg.Name or "Slider",Font=Enum.Font.Gotham,TextSize=12,
                TextColor3=T.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,
                Size=UDim2.new(0.7,0,1,0),Parent=top})
            local vl=Label({Text=tostring(math.floor(val)),Font=Enum.Font.Code,TextSize=12,
                TextColor3=T.Accent,TextXAlignment=Enum.TextXAlignment.Right,
                Size=UDim2.new(0.3,0,1,0),Position=UDim2.new(0.7,0,0,0),Parent=top})
            local trk=Frame({Size=UDim2.new(1,0,0,5),Position=UDim2.new(0,0,1,-10),
                BackgroundColor3=T.BorderDim,ClipsDescendants=true,Parent=wrap})
            Round(trk,3)
            local fill=Frame({Size=UDim2.new((val-mn)/(mx-mn),0,1,0),BackgroundColor3=T.Accent,Parent=trk})
            GradientStripe(fill)
            local hdl=Frame({Size=UDim2.new(0,14,0,14),AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new((val-mn)/(mx-mn),0,0.5,0),
                BackgroundColor3=T.White,ZIndex=3,Parent=trk})
            Round(hdl,7); Stroke(hdl,T.Accent,2)
            local db=Instance.new("TextButton")
            db.Size=UDim2.new(1,0,0,28); db.Position=UDim2.new(0,0,1,-22)
            db.Text=""; db.BackgroundTransparency=1; db.ZIndex=10; db.Parent=wrap
            local ds=false
            db.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then ds=true end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then ds=false end end)
            UserInputService.InputChanged:Connect(function(i)
                if ds and i.UserInputType==Enum.UserInputType.MouseMovement then
                    local rel=math.clamp((i.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1)
                    val=math.floor(mn+rel*(mx-mn))
                    vl.Text=tostring(val); fill.Size=UDim2.new(rel,0,1,0); hdl.Position=UDim2.new(rel,0,0.5,0)
                    if cfg.Callback then task.spawn(cfg.Callback,val) end
                end
            end)
            return {
                Get=function() return val end,
                Set=function(v)
                    v=math.clamp(math.floor(v),mn,mx); val=v
                    local rel=(v-mn)/(mx-mn)
                    vl.Text=tostring(v); fill.Size=UDim2.new(rel,0,1,0); hdl.Position=UDim2.new(rel,0,0.5,0)
                end,
            }
        end

        function Tab:AddDropdown(cfg)
            cfg=cfg or {}
            local opts=cfg.Options or {"Option 1"}
            local sel=cfg.Default or opts[1]
            local open=false
            local wrap=Frame({Size=UDim2.new(1,0,0,38),BackgroundColor3=T.SurfaceAlt,
                ClipsDescendants=false,ZIndex=5,Parent=Page})
            Round(wrap,8); Stroke(wrap,T.BorderDim,1); Pad(wrap,0,0,14,14)
            Label({Text=cfg.Name or "Dropdown",Font=Enum.Font.Gotham,TextSize=12,
                TextColor3=T.TextSecondary,TextXAlignment=Enum.TextXAlignment.Left,
                Size=UDim2.new(0.5,0,1,0),ZIndex=5,Parent=wrap})
            local selLbl=Label({Text=tostring(sel),Font=Enum.Font.GothamBold,TextSize=12,
                TextColor3=T.TextPrimary,TextXAlignment=Enum.TextXAlignment.Right,
                Size=UDim2.new(0.45,0,1,0),Position=UDim2.new(0.5,0,0,0),ZIndex=5,Parent=wrap})
            local arrow=Label({Text="v",Font=Enum.Font.GothamBold,TextSize=12,TextColor3=T.Accent,
                Size=UDim2.new(0,16,1,0),Position=UDim2.new(1,-16,0,0),ZIndex=5,Parent=wrap})
            local menu=Frame({Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,4),
                BackgroundColor3=T.Surface,ClipsDescendants=true,ZIndex=20,Visible=false,Parent=wrap})
            Round(menu,8); Stroke(menu,T.Border,1); ListLayout(menu,Enum.FillDirection.Vertical,0)
            local ih=32
            for _,opt in ipairs(opts) do
                local item=Instance.new("TextButton")
                item.Text=tostring(opt); item.Font=Enum.Font.Gotham; item.TextSize=12
                item.TextColor3=T.TextPrimary; item.Size=UDim2.new(1,0,0,ih)
                item.BackgroundColor3=T.Surface; item.BackgroundTransparency=1
                item.BorderSizePixel=0; item.ZIndex=20; item.TextXAlignment=Enum.TextXAlignment.Left
                item.Parent=menu; Pad(item,0,0,14,0)
                item.MouseEnter:Connect(function() Tw(item,{BackgroundColor3=T.SurfaceAlt,BackgroundTransparency=0},TI.Fast) end)
                item.MouseLeave:Connect(function() Tw(item,{BackgroundTransparency=1},TI.Fast) end)
                item.MouseButton1Click:Connect(function()
                    sel=opt; selLbl.Text=tostring(opt); open=false
                    menu.Visible=false; Tw(arrow,{Rotation=0},TI.Fast)
                    if cfg.Callback then task.spawn(cfg.Callback,opt) end
                end)
            end
            local tog=Instance.new("TextButton")
            tog.Size=UDim2.new(1,0,1,0); tog.Text=""; tog.BackgroundTransparency=1; tog.ZIndex=10; tog.Parent=wrap
            tog.MouseButton1Click:Connect(function()
                open=not open; menu.Visible=open
                if open then
                    menu.Size=UDim2.new(1,0,0,0)
                    Tw(menu,{Size=UDim2.new(1,0,0,#opts*ih)},TI.Med); Tw(arrow,{Rotation=180},TI.Fast)
                else
                    Tw(menu,{Size=UDim2.new(1,0,0,0)},TI.Med); Tw(arrow,{Rotation=0},TI.Fast)
                end
            end)
            return {Get=function() return sel end, Set=function(v) sel=v; selLbl.Text=tostring(v) end}
        end

        function Tab:AddTextBox(cfg)
            cfg=cfg or {}
            local wrap=Frame({Size=UDim2.new(1,0,0,56),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(wrap,8); Stroke(wrap,T.BorderDim,1); Pad(wrap,6,6,14,14)
            Label({Text=cfg.Name or "Input",Font=Enum.Font.Gotham,TextSize=11,
                TextColor3=T.TextMuted,TextXAlignment=Enum.TextXAlignment.Left,
                Size=UDim2.new(1,0,0,16),Parent=wrap})
            local box=Instance.new("TextBox")
            box.Text=tostring(cfg.Default or ""); box.PlaceholderText=cfg.Placeholder or "Type here..."
            box.PlaceholderColor3=T.TextDim; box.Font=Enum.Font.Gotham; box.TextSize=12
            box.TextColor3=T.TextPrimary; box.BackgroundColor3=T.BG; box.BorderSizePixel=0
            box.Size=UDim2.new(1,0,0,24); box.Position=UDim2.new(0,0,1,-24)
            box.TextXAlignment=Enum.TextXAlignment.Left; box.ClearTextOnFocus=false; box.Parent=wrap
            Round(box,6); Stroke(box,T.BorderDim,1); Pad(box,0,0,8,8)
            box.Focused:Connect(function() Stroke(box,T.Accent,1) end)
            box.FocusLost:Connect(function(e)
                Stroke(box,T.BorderDim,1)
                if cfg.Callback then task.spawn(cfg.Callback,box.Text,e) end
            end)
            return {Get=function() return box.Text end, Set=function(v) box.Text=tostring(v) end}
        end

        return Tab
    end -- CreateTab

    -- ── Notify toast ───────────────────────────
    function WindowObj:Notify(cfg)
        cfg=cfg or {}
        local col=cfg.Color or T.Accent
        local toast=Frame({Size=UDim2.new(0,280,0,0),Position=UDim2.new(1,20,1,-20),
            AnchorPoint=Vector2.new(0,1),BackgroundColor3=T.Surface,
            AutomaticSize=Enum.AutomaticSize.Y,ClipsDescendants=true,
            ZIndex=50,Parent=ScreenGui})
        Round(toast,10); Stroke(toast,col,1)
        Frame({Size=UDim2.new(0,3,1,0),BackgroundColor3=col,Parent=toast})
        Pad(toast,10,10,14,14)
        Label({Text=cfg.Message or "Notification",Font=Enum.Font.Gotham,TextSize=12,
            TextColor3=T.TextPrimary,TextWrapped=true,AutomaticSize=Enum.AutomaticSize.Y,
            Size=UDim2.new(1,-8,0,0),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=51,Parent=toast})
        Tw(toast,{Position=UDim2.new(1,-300,1,-20)},TI.Med)
        task.delay(cfg.Duration or 3,function()
            Tw(toast,{Position=UDim2.new(1,20,1,-20)},TI.Med)
            task.delay(0.35,function() toast:Destroy() end)
        end)
    end

    -- Play intro → open window → spawn watermark
    task.spawn(function()
        PlayIntro(function()
            task.wait(0.08)
            Win.BackgroundTransparency = 1
            Win.Size = UDim2.new(0,WinSize.X,0,0)
            Tw(Win,{BackgroundTransparency=0},TI.Med)
            Tw(Win,{Size=UDim2.new(0,WinSize.X,0,WinSize.Y)},TI.Spring)
            task.wait(0.25)
            CreateWatermark(ScreenGui)
        end)
    end)

    return WindowObj
end

return Library
