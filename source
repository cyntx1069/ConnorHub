    local SubLbl = Label({ Text="Universal Utility Tool  *  v3.0", Font=Enum.Font.Gotham, TextSize=11, TextColor3=T.TextMuted, TextTransparency=1, Size=UDim2.new(1,0,0,20), Position=UDim2.new(0,0,0,118), TextXAlignment=Enum.TextXAlignment.Center, Parent=Card })
    local BarTrack = Frame({ Size=UDim2.new(0,200,0,3), Position=UDim2.new(0.5,-100,1,-20), BackgroundColor3=T.BorderDim, Parent=Card })
    Round(BarTrack, 2)
    local BarFill = Frame({ Size=UDim2.new(0,0,1,0), BackgroundColor3=T.Accent, Parent=BarTrack })
    Round(BarFill, 2); GradientStripe(BarFill)

    Tw(BG,   { BackgroundTransparency=0.10 }, TI.Intro); Tw(blur, { Size=24 }, TI.Intro)
    task.wait(0.15); Tw(Card, { BackgroundTransparency=0 }, TI.Med)
    task.wait(0.10); Tw(TopLine, { Size=UDim2.new(1,0,0,2) }, TI.Med)
    task.wait(0.10); Tw(LogoDot, { BackgroundColor3=T.AccentBright }, TI.Fast)
    task.wait(0.08); Tw(LogoDot, { BackgroundColor3=T.Accent }, TI.Med); Tw(TitleLbl, { TextTransparency=0 }, TI.Med)
    task.wait(0.10); Tw(AccentWord, { TextTransparency=0 }, TI.Med)
    task.wait(0.08); Tw(SubLbl, { TextTransparency=0 }, TI.Med)
    task.wait(0.15); Tw(BarFill, { Size=UDim2.new(1,0,1,0) }, TweenInfo.new(0.9, Enum.EasingStyle.Quint, Enum.EasingDirection.Out))
    task.wait(1.05)
    Tw(TitleLbl, { TextTransparency=1 }, TI.Med); Tw(AccentWord, { TextTransparency=1 }, TI.Med); Tw(SubLbl, { TextTransparency=1 }, TI.Med)
    task.wait(0.08); Tw(Card, { BackgroundTransparency=1 }, TI.Med)
    task.wait(0.05); Tw(blur, { Size=0 }, TI.Slow); Tw(BG, { BackgroundTransparency=1 }, TI.Slow)
    task.wait(0.50); blur:Destroy(); Gui:Destroy()
    if onComplete then onComplete() end
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
--  ✦  LIBRARY
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local Library = {}
Library.__index = Library

function Library:CreateWindow(config)
    config = config or {}
    local Title    = config.Title    or "ConnorHub"
    local SubTitle = config.SubTitle or "v3.0"
    local WinSize  = config.Size     or Vector2.new(600, 460)

    -- Keybind state
    local CurrentKey   = Enum.KeyCode.Insert
    local UIVisible    = true

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "ConnorHub"; ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.IgnoreGuiInset = true; ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    local Win = Frame({
        Name = "Window", Size = UDim2.new(0,WinSize.X,0,0),
        Position = UDim2.new(0.5,-WinSize.X/2,0.5,-WinSize.Y/2),
        BackgroundColor3 = T.BG, BackgroundTransparency = 1, ClipsDescendants = true, Parent = ScreenGui,
    })
    Round(Win, 14); Stroke(Win, T.Border, 1)
    RegisterTheme(Win, "BackgroundColor3", "BG")

    local Stripe = Frame({ Size=UDim2.new(1,0,0,2), BackgroundColor3=T.Accent, ZIndex=5, Parent=Win })
    Round(Stripe, 2); GradientStripe(Stripe)
    RegisterTheme(Stripe, "BackgroundColor3", "Accent")

    local TBar = Frame({ Size=UDim2.new(1,0,0,52), BackgroundColor3=T.Surface, Parent=Win })
    RegisterTheme(TBar, "BackgroundColor3", "Surface")
    Frame({ Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1), BackgroundColor3=T.Border, Parent=TBar })

    local Dot = Frame({ Size=UDim2.new(0,10,0,10), Position=UDim2.new(0,16,0.5,-5), BackgroundColor3=T.Accent, Parent=TBar })
    Round(Dot, 5); RegisterTheme(Dot, "BackgroundColor3", "Accent")
    Frame({ Size=UDim2.new(0,22,0,22), Position=UDim2.new(0,10,0.5,-11), BackgroundColor3=T.Accent, BackgroundTransparency=0.72, ZIndex=Dot.ZIndex-1, Parent=TBar })

    local TitleLbl = Label({ Text=Title:upper(), Font=Enum.Font.GothamBold, TextSize=14, TextColor3=T.TextPrimary, TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(0,140,1,0), Position=UDim2.new(0,34,0,0), Parent=TBar })
    RegisterTheme(TitleLbl, "TextColor3", "TextPrimary")
    local SubLbl = Label({ Text=SubTitle, Font=Enum.Font.Gotham, TextSize=11, TextColor3=T.TextSecondary, TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(0,60,1,0), Position=UDim2.new(0,130,0,0), Parent=TBar })
    RegisterTheme(SubLbl, "TextColor3", "TextSecondary")

    local function WinBtn(lbl, xOff)
        local b = Instance.new("TextButton")
        b.Text=lbl; b.Font=Enum.Font.GothamBold; b.TextSize=12; b.TextColor3=T.TextSecondary
        b.Size=UDim2.new(0,30,0,30); b.Position=UDim2.new(1,xOff,0.5,-15); b.BackgroundColor3=T.SurfaceAlt
        b.BorderSizePixel=0; b.Parent=TBar; Round(b,7)
        return b
    end
    local CloseBtn = WinBtn("X", -42); local MinBtn = WinBtn("-", -78)
    RegisterTheme(CloseBtn, "BackgroundColor3", "SurfaceAlt"); RegisterTheme(CloseBtn, "TextColor3", "TextSecondary")
    RegisterTheme(MinBtn,   "BackgroundColor3", "SurfaceAlt"); RegisterTheme(MinBtn,   "TextColor3", "TextSecondary")

    CloseBtn.MouseEnter:Connect(function() Tw(CloseBtn,{BackgroundColor3=T.Danger,TextColor3=T.White}) end)
    CloseBtn.MouseLeave:Connect(function() Tw(CloseBtn,{BackgroundColor3=T.SurfaceAlt,TextColor3=T.TextSecondary}) end)
    CloseBtn.MouseButton1Click:Connect(function()
        -- Animate out
        Tw(Win,{Size=UDim2.new(0,WinSize.X,0,0),BackgroundTransparency=1},TI.Med)
        task.delay(0.32, function()
            -- Destroy main gui
            pcall(function() ScreenGui:Destroy() end)
            -- Destroy intro gui if still alive (e.g. user closes during intro)
            local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
            if playerGui then
                local introGui = playerGui:FindFirstChild("ConnorHub_Intro")
                if introGui then introGui:Destroy() end
            end
            -- Remove any lingering blur we added to Lighting
            for _, v in ipairs(Lighting:GetChildren()) do
                if v:IsA("BlurEffect") and v.Name == "BlurEffect" then
                    v:Destroy()
                end
            end
            -- Clear theme registry so no stale refs remain
            table.clear(ThemeRegistry)
        end)
    end)

    local minimised = false
    MinBtn.MouseEnter:Connect(function() Tw(MinBtn,{BackgroundColor3=T.AccentDim,TextColor3=T.Accent}) end)
    MinBtn.MouseLeave:Connect(function() Tw(MinBtn,{BackgroundColor3=T.SurfaceAlt,TextColor3=T.TextSecondary}) end)
    MinBtn.MouseButton1Click:Connect(function()
        minimised = not minimised
        if minimised then Tw(Win,{Size=UDim2.new(0,WinSize.X,0,52)},TI.Med)
        else Tw(Win,{Size=UDim2.new(0,WinSize.X,0,WinSize.Y)},TI.Spring) end
    end)

    -- Draggable title bar
    do
        local drag, dStart, sPos
        TBar.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                drag=true; dStart=inp.Position; sPos=Win.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if drag and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local d = inp.Position - dStart
                Win.Position = UDim2.new(sPos.X.Scale,sPos.X.Offset+d.X,sPos.Y.Scale,sPos.Y.Offset+d.Y)
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
        end)
    end

    local Sidebar = Frame({ Size=UDim2.new(0,148,1,-52), Position=UDim2.new(0,0,0,52), BackgroundColor3=T.Surface, Parent=Win })
    RegisterTheme(Sidebar, "BackgroundColor3", "Surface")
    Frame({ Size=UDim2.new(0,1,1,0), Position=UDim2.new(1,-1,0,0), BackgroundColor3=T.Border, Parent=Sidebar })

    local TabScroll = Instance.new("ScrollingFrame")
    TabScroll.Size=UDim2.new(1,0,1,0); TabScroll.BackgroundTransparency=1; TabScroll.ScrollBarThickness=0; TabScroll.Parent=Sidebar
    Pad(TabScroll,10,10,8,8)
    local TabList = ListLayout(TabScroll,Enum.FillDirection.Vertical,4)
    TabList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        TabScroll.CanvasSize=UDim2.new(0,0,0,TabList.AbsoluteContentSize.Y+20)
    end)

    local Indicator = Frame({ Size=UDim2.new(0,3,0,34), Position=UDim2.new(0,0,0,10), BackgroundColor3=T.Accent, ZIndex=10, Parent=Sidebar })
    Round(Indicator, 2); RegisterTheme(Indicator, "BackgroundColor3", "Accent")

    local ContentArea = Frame({ Size=UDim2.new(1,-148,1,-52), Position=UDim2.new(0,148,0,52), BackgroundColor3=T.BG, ClipsDescendants=true, Parent=Win })
    RegisterTheme(ContentArea, "BackgroundColor3", "BG")

    local AllTabs  = {}
    local ActiveTab = nil

    local function SetActive(tab)
        if ActiveTab == tab then return end
        ActiveTab = tab
        for _, t in pairs(AllTabs) do
            local on = (t == tab)
            Tw(t._btn,   {BackgroundColor3 = on and T.AccentDim or T.Surface, BackgroundTransparency = on and 0 or 1})
            Tw(t._icon,  {TextColor3 = on and T.Accent or T.TextDim})
            Tw(t._label, {TextColor3 = on and T.TextPrimary or T.TextSecondary})
            t._page.Visible = on
            if on then
                local py = t._btn.AbsolutePosition.Y - Sidebar.AbsolutePosition.Y
                Tw(Indicator,{Position=UDim2.new(0,0,0,py+1)},TI.Med)
                t._page.Position = UDim2.new(0.04,0,0,0)
                Tw(t._page,{Position=UDim2.new(0,0,0,0)},TI.Med)
            end
        end
    end

    -- Wire up the global hook so ApplyTheme can refresh tab btn colours
    _onThemeApplied = function()
        -- Re-stamp every tab button with the new theme's active/inactive colours
        for _, t in pairs(AllTabs) do
            local on = (t == ActiveTab)
            pcall(function()
                t._btn.BackgroundColor3       = on and T.AccentDim or T.Surface
                t._btn.BackgroundTransparency = on and 0 or 1
                t._icon.TextColor3  = on and T.Accent or T.TextDim
                t._label.TextColor3 = on and T.TextPrimary or T.TextSecondary
                t._page.BackgroundColor3 = T.BG
            end)
        end
        -- Also re-stamp indicator
        pcall(function() Indicator.BackgroundColor3 = T.Accent end)
        -- Re-stamp sidebar and content area backgrounds
        pcall(function() Sidebar.BackgroundColor3      = T.Surface end)
        pcall(function() ContentArea.BackgroundColor3  = T.BG end)
        pcall(function() Win.BackgroundColor3          = T.BG end)
        pcall(function() TBar.BackgroundColor3         = T.Surface end)
    end

    local WindowObj = {}

    -- ──────────────────────────────────────────────
    --  Element builder (shared by all tabs)
    -- ──────────────────────────────────────────────
    local function BuildElements(Tab, Page)

        function Tab:AddSection(title)
            local w = Frame({Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,Parent=Page})
            Frame({Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0.5,0),BackgroundColor3=T.BorderDim,Parent=w})
            local lbl = Label({Text="  "..title:upper().."  ",Font=Enum.Font.GothamBold,TextSize=9,
                TextColor3=T.TextMuted,BackgroundColor3=T.BG,
                Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,ZIndex=2,Parent=w})
            RegisterTheme(lbl, "TextColor3", "TextMuted")
            RegisterTheme(lbl, "BackgroundColor3", "BG")
        end

        function Tab:AddSeparator()
            Frame({Size=UDim2.new(1,0,0,1),BackgroundColor3=T.BorderDim,Parent=Page})
        end

        function Tab:AddLabel(cfg)
            cfg=cfg or {}
            local row=Frame({Size=UDim2.new(1,0,0,38),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(row,8); Stroke(row,T.BorderDim,1); Pad(row,0,0,14,14)
            RegisterTheme(row, "BackgroundColor3", "SurfaceAlt")
            local tl = Label({Text=cfg.Name or "Label",Font=Enum.Font.Gotham,TextSize=12,
                TextColor3=T.TextSecondary,TextXAlignment=Enum.TextXAlignment.Left,Size=UDim2.new(0.55,0,1,0),Parent=row})
            RegisterTheme(tl, "TextColor3", "TextSecondary")
            local vl=Label({Text=tostring(cfg.Value or "--"),Font=Enum.Font.Code,TextSize=12,
                TextColor3=cfg.Color or T.Accent,TextXAlignment=Enum.TextXAlignment.Right,
                Size=UDim2.new(0.45,0,1,0),Position=UDim2.new(0.55,0,0,0),Parent=row})
            if not cfg.Color then RegisterTheme(vl, "TextColor3", "Accent") end
            return {Set=function(v) vl.Text=tostring(v) end, SetColor=function(c) vl.TextColor3=c end}
        end

        function Tab:AddBadge(cfg)
            cfg=cfg or {}
            local cm={accent=T.Accent,success=T.Success,warning=T.Warning,danger=T.Danger}
            local bc=cm[cfg.Color or "accent"] or T.Accent
            local row=Frame({Size=UDim2.new(1,0,0,38),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(row,8); Stroke(row,T.BorderDim,1); Pad(row,0,0,14,14)
            RegisterTheme(row, "BackgroundColor3", "SurfaceAlt")
            local tl = Label({Text=cfg.Name or "Badge",Font=Enum.Font.Gotham,TextSize=12,
                TextColor3=T.TextSecondary,TextXAlignment=Enum.TextXAlignment.Left,Size=UDim2.new(0.6,0,1,0),Parent=row})
            RegisterTheme(tl, "TextColor3", "TextSecondary")
            local bf=Frame({Size=UDim2.new(0,0,0,20),AutomaticSize=Enum.AutomaticSize.X,
                Position=UDim2.new(1,-2,0.5,-10),AnchorPoint=Vector2.new(1,0),BackgroundColor3=bc,Parent=row})
            Round(bf,10); Pad(bf,0,0,9,9)
            Label({Text=tostring(cfg.Badge or ""),Font=Enum.Font.GothamBold,TextSize=10,TextColor3=T.White,Size=UDim2.new(1,0,1,0),Parent=bf})
        end

        function Tab:AddButton(cfg)
            cfg=cfg or {}
            local bgMap={primary=T.Accent,secondary=T.SurfaceAlt,danger=T.Danger,success=T.Success}
            local bg=bgMap[cfg.Style or "primary"] or T.Accent
            local tc=(cfg.Style=="secondary") and T.TextPrimary or T.White
            local btn=Instance.new("TextButton")
            btn.Text=cfg.Name or "Button"; btn.Font=Enum.Font.GothamBold; btn.TextSize=12
            btn.TextColor3=tc; btn.Size=UDim2.new(1,0,0,38); btn.BackgroundColor3=bg; btn.BorderSizePixel=0; btn.Parent=Page
            Round(btn,8)
            if cfg.Style=="secondary" then Stroke(btn,T.Border,1) end
            if cfg.Style=="primary" then RegisterTheme(btn,"BackgroundColor3","Accent") end
            local function B(c) return Color3.new(math.min(c.R+0.09,1),math.min(c.G+0.09,1),math.min(c.B+0.09,1)) end
            btn.MouseButton1Down:Connect(function() Tw(btn,{Size=UDim2.new(0.98,0,0,34),Position=UDim2.new(0.01,0,0,2)},TI.Fast) end)
            btn.MouseButton1Up:Connect(function()
                Tw(btn,{Size=UDim2.new(1,0,0,38),Position=UDim2.new(0,0,0,0),BackgroundColor3=bg},TI.Fast)
                if cfg.Callback then task.spawn(cfg.Callback) end
            end)
            btn.MouseEnter:Connect(function() Tw(btn,{BackgroundColor3=B(bg)},TI.Fast) end)
            btn.MouseLeave:Connect(function() Tw(btn,{BackgroundColor3=bg},TI.Fast) end)
            return btn
        end

        function Tab:AddToggle(cfg)
            cfg=cfg or {}
            local state=cfg.Default or false
            local row=Frame({Size=UDim2.new(1,0,0,44),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(row,8); Stroke(row,T.BorderDim,1); Pad(row,0,0,14,14)
            RegisterTheme(row, "BackgroundColor3", "SurfaceAlt")
            local tl = Label({Text=cfg.Name or "Toggle",Font=Enum.Font.Gotham,TextSize=12,
                TextColor3=T.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,Size=UDim2.new(0.68,0,1,0),Parent=row})
            RegisterTheme(tl, "TextColor3", "TextPrimary")
            local track=Frame({Size=UDim2.new(0,44,0,24),Position=UDim2.new(1,-44,0.5,-12),
                BackgroundColor3=state and T.Accent or T.BorderDim,Parent=row})
            Round(track,12)
            local thumb=Frame({Size=UDim2.new(0,18,0,18),Position=state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9),BackgroundColor3=T.White,ZIndex=2,Parent=track})
            Round(thumb,9)
            local cb=Instance.new("TextButton"); cb.Size=UDim2.new(1,0,1,0); cb.Text=""; cb.BackgroundTransparency=1; cb.ZIndex=5; cb.Parent=row
            local function Refresh()
                Tw(thumb,{Position=state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)},TI.Med)
                Tw(track,{BackgroundColor3=state and T.Accent or T.BorderDim},TI.Med)
            end
            cb.MouseButton1Click:Connect(function() state=not state; Refresh(); if cfg.Callback then task.spawn(cfg.Callback,state) end end)
            return {Get=function() return state end, Set=function(v) state=v; Refresh() end}
        end

        function Tab:AddSlider(cfg)
            cfg=cfg or {}
            local mn=cfg.Min or 0; local mx=cfg.Max or 100
            local val=math.clamp(cfg.Default or mn,mn,mx)
            local wrap=Frame({Size=UDim2.new(1,0,0,58),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(wrap,8); Stroke(wrap,T.BorderDim,1); Pad(wrap,8,8,14,14)
            RegisterTheme(wrap,"BackgroundColor3","SurfaceAlt")
            local top=Frame({Size=UDim2.new(1,0,0,20),BackgroundTransparency=1,Parent=wrap})
            local tl = Label({Text=cfg.Name or "Slider",Font=Enum.Font.Gotham,TextSize=12,TextColor3=T.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,Size=UDim2.new(0.7,0,1,0),Parent=top})
            RegisterTheme(tl,"TextColor3","TextPrimary")
            local vl=Label({Text=tostring(math.floor(val)),Font=Enum.Font.Code,TextSize=12,TextColor3=T.Accent,TextXAlignment=Enum.TextXAlignment.Right,Size=UDim2.new(0.3,0,1,0),Position=UDim2.new(0.7,0,0,0),Parent=top})
            RegisterTheme(vl,"TextColor3","Accent")
            local trk=Frame({Size=UDim2.new(1,0,0,5),Position=UDim2.new(0,0,1,-10),BackgroundColor3=T.BorderDim,ClipsDescendants=true,Parent=wrap})
            Round(trk,3); RegisterTheme(trk,"BackgroundColor3","BorderDim")
            local fill=Frame({Size=UDim2.new((val-mn)/(mx-mn),0,1,0),BackgroundColor3=T.Accent,Parent=trk})
            GradientStripe(fill); RegisterTheme(fill,"BackgroundColor3","Accent")
            local hdl=Frame({Size=UDim2.new(0,14,0,14),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new((val-mn)/(mx-mn),0,0.5,0),BackgroundColor3=T.White,ZIndex=3,Parent=trk})
            Round(hdl,7); Stroke(hdl,T.Accent,2)
            local db=Instance.new("TextButton"); db.Size=UDim2.new(1,0,0,28); db.Position=UDim2.new(0,0,1,-22); db.Text=""; db.BackgroundTransparency=1; db.ZIndex=10; db.Parent=wrap
            local ds=false
            db.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then ds=true end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then ds=false end end)
            UserInputService.InputChanged:Connect(function(i)
                if ds and i.UserInputType==Enum.UserInputType.MouseMovement then
                    local rel=math.clamp((i.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1)
                    val=math.floor(mn+rel*(mx-mn)); vl.Text=tostring(val); fill.Size=UDim2.new(rel,0,1,0); hdl.Position=UDim2.new(rel,0,0.5,0)
                    if cfg.Callback then task.spawn(cfg.Callback,val) end
                end
            end)
            return {
                Get=function() return val end,
                Set=function(v)
                    v=math.clamp(math.floor(v),mn,mx); val=v; local rel=(v-mn)/(mx-mn)
                    vl.Text=tostring(v); fill.Size=UDim2.new(rel,0,1,0); hdl.Position=UDim2.new(rel,0,0.5,0)
                end,
            }
        end

        function Tab:AddDropdown(cfg)
            cfg=cfg or {}
            local opts=cfg.Options or {"Option 1"}; local sel=cfg.Default or opts[1]; local open=false
            local wrap=Frame({Size=UDim2.new(1,0,0,38),BackgroundColor3=T.SurfaceAlt,ClipsDescendants=false,ZIndex=5,Parent=Page})
            Round(wrap,8); Stroke(wrap,T.BorderDim,1); Pad(wrap,0,0,14,14)
            RegisterTheme(wrap,"BackgroundColor3","SurfaceAlt")
            local nl = Label({Text=cfg.Name or "Dropdown",Font=Enum.Font.Gotham,TextSize=12,TextColor3=T.TextSecondary,TextXAlignment=Enum.TextXAlignment.Left,Size=UDim2.new(0.5,0,1,0),ZIndex=5,Parent=wrap})
            RegisterTheme(nl,"TextColor3","TextSecondary")
            local selLbl=Label({Text=tostring(sel),Font=Enum.Font.GothamBold,TextSize=12,TextColor3=T.TextPrimary,TextXAlignment=Enum.TextXAlignment.Right,Size=UDim2.new(0.45,0,1,0),Position=UDim2.new(0.5,0,0,0),ZIndex=5,Parent=wrap})
            RegisterTheme(selLbl,"TextColor3","TextPrimary")
            local arrow=Label({Text="v",Font=Enum.Font.GothamBold,TextSize=12,TextColor3=T.Accent,Size=UDim2.new(0,16,1,0),Position=UDim2.new(1,-16,0,0),ZIndex=5,Parent=wrap})
            RegisterTheme(arrow,"TextColor3","Accent")
            local menu=Frame({Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,4),BackgroundColor3=T.Surface,ClipsDescendants=true,ZIndex=20,Visible=false,Parent=wrap})
            Round(menu,8); Stroke(menu,T.Border,1); ListLayout(menu,Enum.FillDirection.Vertical,0)
            RegisterTheme(menu,"BackgroundColor3","Surface")
            local ih=32
            for _,opt in ipairs(opts) do
                local item=Instance.new("TextButton"); item.Text=tostring(opt); item.Font=Enum.Font.Gotham; item.TextSize=12
                item.TextColor3=T.TextPrimary; item.Size=UDim2.new(1,0,0,ih); item.BackgroundColor3=T.Surface; item.BackgroundTransparency=1
                item.BorderSizePixel=0; item.ZIndex=20; item.TextXAlignment=Enum.TextXAlignment.Left; item.Parent=menu; Pad(item,0,0,14,0)
                RegisterTheme(item,"TextColor3","TextPrimary"); RegisterTheme(item,"BackgroundColor3","Surface")
                item.MouseEnter:Connect(function() Tw(item,{BackgroundColor3=T.SurfaceAlt,BackgroundTransparency=0},TI.Fast) end)
                item.MouseLeave:Connect(function() Tw(item,{BackgroundTransparency=1},TI.Fast) end)
                item.MouseButton1Click:Connect(function()
                    sel=opt; selLbl.Text=tostring(opt); open=false; menu.Visible=false; Tw(arrow,{Rotation=0},TI.Fast)
                    if cfg.Callback then task.spawn(cfg.Callback,opt) end
                end)
            end
            local tog=Instance.new("TextButton"); tog.Size=UDim2.new(1,0,1,0); tog.Text=""; tog.BackgroundTransparency=1; tog.ZIndex=10; tog.Parent=wrap
            tog.MouseButton1Click:Connect(function()
                open=not open; menu.Visible=open
                if open then menu.Size=UDim2.new(1,0,0,0); Tw(menu,{Size=UDim2.new(1,0,0,#opts*ih)},TI.Med); Tw(arrow,{Rotation=180},TI.Fast)
                else Tw(menu,{Size=UDim2.new(1,0,0,0)},TI.Med); Tw(arrow,{Rotation=0},TI.Fast) end
            end)
            return {Get=function() return sel end, Set=function(v) sel=v; selLbl.Text=tostring(v) end}
        end

        function Tab:AddTextBox(cfg)
            cfg=cfg or {}
            local wrap=Frame({Size=UDim2.new(1,0,0,56),BackgroundColor3=T.SurfaceAlt,Parent=Page})
            Round(wrap,8); Stroke(wrap,T.BorderDim,1); Pad(wrap,6,6,14,14)
            RegisterTheme(wrap,"BackgroundColor3","SurfaceAlt")
            local tl = Label({Text=cfg.Name or "Input",Font=Enum.Font.Gotham,TextSize=11,TextColor3=T.TextMuted,TextXAlignment=Enum.TextXAlignment.Left,Size=UDim2.new(1,0,0,16),Parent=wrap})
            RegisterTheme(tl,"TextColor3","TextMuted")
            local box=Instance.new("TextBox"); box.Text=tostring(cfg.Default or ""); box.PlaceholderText=cfg.Placeholder or "Type here..."
            box.PlaceholderColor3=T.TextDim; box.Font=Enum.Font.Gotham; box.TextSize=12; box.TextColor3=T.TextPrimary
            box.BackgroundColor3=T.BG; box.BorderSizePixel=0; box.Size=UDim2.new(1,0,0,24); box.Position=UDim2.new(0,0,1,-24)
            box.TextXAlignment=Enum.TextXAlignment.Left; box.ClearTextOnFocus=false; box.Parent=wrap
            Round(box,6); Stroke(box,T.BorderDim,1); Pad(box,0,0,8,8)
            RegisterTheme(box,"TextColor3","TextPrimary"); RegisterTheme(box,"BackgroundColor3","BG")
            box.Focused:Connect(function() Stroke(box,T.Accent,1) end)
            box.FocusLost:Connect(function(e) Stroke(box,T.BorderDim,1); if cfg.Callback then task.spawn(cfg.Callback,box.Text,e) end end)
            return {Get=function() return box.Text end, Set=function(v) box.Text=tostring(v) end}
        end

        return Tab
    end -- BuildElements

    -- ──────────────────────────────────────────────
    --  Window:CreateTab
    -- ──────────────────────────────────────────────
    function WindowObj:CreateTab(cfg)
        cfg = cfg or {}
        local name = cfg.Name or "Tab"; local icon = cfg.Icon or "*"

        local Btn = Instance.new("TextButton")
        Btn.Size=UDim2.new(1,0,0,34); Btn.BackgroundColor3=T.AccentDim; Btn.BackgroundTransparency=1
        Btn.BorderSizePixel=0; Btn.Text=""; Btn.Parent=TabScroll; Round(Btn,8)

        local BtnIcon = Label({ Text=icon, Font=Enum.Font.Gotham, TextSize=14, TextColor3=T.TextDim, Size=UDim2.new(0,28,1,0), Position=UDim2.new(0,8,0,0), Parent=Btn })
        local BtnLabel = Label({ Text=name, Font=Enum.Font.Gotham, TextSize=12, TextColor3=T.TextSecondary, TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(1,-40,1,0), Position=UDim2.new(0,36,0,0), Parent=Btn })
        RegisterTheme(BtnIcon,"TextColor3","TextDim"); RegisterTheme(BtnLabel,"TextColor3","TextSecondary")

        local Page = Instance.new("ScrollingFrame")
        Page.Size=UDim2.new(1,0,1,0); Page.BackgroundColor3=T.BG; Page.BackgroundTransparency=0
        Page.BorderSizePixel=0; Page.ScrollBarThickness=3; Page.ScrollBarImageColor3=T.Accent
        Page.ScrollBarImageTransparency=0.4; Page.Visible=false; Page.Parent=ContentArea
        Pad(Page,14,14,16,16)
        local PageList = ListLayout(Page,Enum.FillDirection.Vertical,8)
        AutoCanvas(Page,PageList)
        RegisterTheme(Page,"BackgroundColor3","BG")

        local tab = {_btn=Btn,_icon=BtnIcon,_label=BtnLabel,_page=Page,_list=PageList}

        Btn.MouseEnter:Connect(function() if ActiveTab~=tab then Tw(Btn,{BackgroundTransparency=0.7,BackgroundColor3=T.SurfaceAlt}) end end)
        Btn.MouseLeave:Connect(function() if ActiveTab~=tab then Tw(Btn,{BackgroundTransparency=1}) end end)
        Btn.MouseButton1Click:Connect(function() SetActive(tab) end)

        table.insert(AllTabs,tab)
        if #AllTabs==1 then task.defer(function() SetActive(tab) end) end

        local Tab = {}
        BuildElements(Tab, Page)
        return Tab
    end

    -- ──────────────────────────────────────────────
    --  Auto-create Settings Tab (always last)
    -- ──────────────────────────────────────────────
    local function CreateSettingsTab()
        local name = "Settings"; local icon = "S"

        local Btn = Instance.new("TextButton")
        Btn.Size=UDim2.new(1,0,0,34); Btn.BackgroundColor3=T.AccentDim; Btn.BackgroundTransparency=1
        Btn.BorderSizePixel=0; Btn.Text=""; Btn.Parent=TabScroll; Round(Btn,8)

        local BtnIcon = Label({ Text=icon, Font=Enum.Font.Gotham, TextSize=14, TextColor3=T.TextDim, Size=UDim2.new(0,28,1,0), Position=UDim2.new(0,8,0,0), Parent=Btn })
        local BtnLabel = Label({ Text=name, Font=Enum.Font.Gotham, TextSize=12, TextColor3=T.TextSecondary, TextXAlignment=Enum.TextXAlignment.Left, Size=UDim2.new(1,-40,1,0), Position=UDim2.new(0,36,0,0), Parent=Btn })
        RegisterTheme(BtnIcon,"TextColor3","TextDim"); RegisterTheme(BtnLabel,"TextColor3","TextSecondary")

        local Page = Instance.new("ScrollingFrame")
        Page.Size=UDim2.new(1,0,1,0); Page.BackgroundColor3=T.BG; Page.BackgroundTransparency=0
        Page.BorderSizePixel=0; Page.ScrollBarThickness=3; Page.ScrollBarImageColor3=T.Accent
        Page.ScrollBarImageTransparency=0.4; Page.Visible=false; Page.Parent=ContentArea
        Pad(Page,14,14,16,16)
        local PageList = ListLayout(Page,Enum.FillDirection.Vertical,8)
        AutoCanvas(Page,PageList)
        RegisterTheme(Page,"BackgroundColor3","BG")

        local tab = {_btn=Btn,_icon=BtnIcon,_label=BtnLabel,_page=Page,_list=PageList}

        Btn.MouseEnter:Connect(function() if ActiveTab~=tab then Tw(Btn,{BackgroundTransparency=0.7,BackgroundColor3=T.SurfaceAlt}) end end)
        Btn.MouseLeave:Connect(function() if ActiveTab~=tab then Tw(Btn,{BackgroundTransparency=1}) end end)
        Btn.MouseButton1Click:Connect(function() SetActive(tab) end)
        table.insert(AllTabs,tab)

        -- ── Section: Keybind ───────────────────────
        do
            local w = Frame({Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,Parent=Page})
            Frame({Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0.5,0),BackgroundColor3=T.BorderDim,Parent=w})
            local sl = Label({Text="  KEYBIND  ",Font=Enum.Font.GothamBold,TextSize=9,TextColor3=T.TextMuted,BackgroundColor3=T.BG,Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,ZIndex=2,Parent=w})
            RegisterTheme(sl,"TextColor3","TextMuted"); RegisterTheme(sl,"BackgroundColor3","BG")
        end

        -- Keybind row
        local listening = false
        local kbRow = Frame({Size=UDim2.new(1,0,0,38),BackgroundColor3=T.SurfaceAlt,Parent=Page})
        Round(kbRow,8); Stroke(kbRow,T.BorderDim,1); Pad(kbRow,0,0,14,14)
        RegisterTheme(kbRow,"BackgroundColor3","SurfaceAlt")

        local kbTitle = Label({Text="Toggle Visibility",Font=Enum.Font.Gotham,TextSize=12,TextColor3=T.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,Size=UDim2.new(0.55,0,1,0),Parent=kbRow})
        RegisterTheme(kbTitle,"TextColor3","TextPrimary")

        local kbBtn = Instance.new("TextButton")
        kbBtn.Font=Enum.Font.Gotham; kbBtn.TextSize=12; kbBtn.TextColor3=T.Accent
        kbBtn.BackgroundColor3=T.AccentDim; kbBtn.BorderSizePixel=0
        kbBtn.Size=UDim2.new(0,90,0,26); kbBtn.Position=UDim2.new(1,-90,0.5,-13)
        kbBtn.Text=CurrentKey.Name; kbBtn.Parent=kbRow; Round(kbBtn,6)
        local kbStroke = Stroke(kbBtn, T.Accent, 1)
        RegisterTheme(kbBtn,"BackgroundColor3","AccentDim"); RegisterTheme(kbBtn,"TextColor3","Accent"); RegisterTheme(kbStroke,"Color","Accent")

        -- (kbHint removed per user request)

        kbBtn.MouseButton1Click:Connect(function()
            if listening then return end
            listening = true
            kbBtn.Text = "Press a key..."
            Tw(kbBtn,{BackgroundColor3=T.Warning,TextColor3=Color3.fromRGB(20,10,0)},TI.Fast)
            local conn
            conn = UserInputService.InputBegan:Connect(function(inp, gpe)
                if gpe then return end
                if inp.UserInputType == Enum.UserInputType.Keyboard then
                    CurrentKey = inp.KeyCode
                    kbBtn.Text = CurrentKey.Name
                    Tw(kbBtn,{BackgroundColor3=T.AccentDim,TextColor3=T.Accent},TI.Fast)
                    listening = false
                    conn:Disconnect()
                end
            end)
        end)

        -- ── Section: Theme ─────────────────────────
        do
            local w = Frame({Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,Parent=Page})
            Frame({Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0.5,0),BackgroundColor3=T.BorderDim,Parent=w})
            local sl = Label({Text="  THEME  ",Font=Enum.Font.GothamBold,TextSize=9,TextColor3=T.TextMuted,BackgroundColor3=T.BG,Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,ZIndex=2,Parent=w})
            RegisterTheme(sl,"TextColor3","TextMuted"); RegisterTheme(sl,"BackgroundColor3","BG")
        end

        -- Theme cards (2x2 grid)
        local themeNames = { "Cynnet", "Dark", "Light", "Orange" }

        local themeColors = {
            Cynnet = Color3.fromRGB(110,0,255),
            Dark   = Color3.fromRGB(255,255,255),
            Light  = Color3.fromRGB(14,14,20),
            Orange = Color3.fromRGB(255,130,0),
        }
        local activeThemeName = "Cynnet"

        local themeGrid = Frame({
            Size = UDim2.new(1,0,0,0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Parent = Page,
        })
        local tgl = Instance.new("UIGridLayout")
        tgl.CellSize = UDim2.new(0.5,-5,0,64)
        tgl.CellPadding = UDim2.new(0,8,0,8)
        tgl.SortOrder = Enum.SortOrder.LayoutOrder
        tgl.Parent = themeGrid
        tgl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            themeGrid.Size = UDim2.new(1,0,0,tgl.AbsoluteContentSize.Y)
        end)

        -- Each card uses FIXED colors from its own theme so previews never change
        local cardPreviewBG = {
            Cynnet = Themes.Cynnet.SurfaceAlt,
            Dark   = Themes.Dark.SurfaceAlt,
            Light  = Themes.Light.Surface,
            Orange = Themes.Orange.SurfaceAlt,
        }
        local cardPreviewText = {
            Cynnet = Themes.Cynnet.TextPrimary,
            Dark   = Themes.Dark.TextPrimary,
            Light  = Themes.Light.TextPrimary,
            Orange = Themes.Orange.TextPrimary,
        }
        -- Badge text: contrast against each theme's accent
        local cardBadgeText = {
            Cynnet = Themes.Cynnet.BG,    -- dark bg on purple badge
            Dark   = Themes.Dark.BG,      -- dark bg on white badge
            Light  = Themes.Light.White,  -- white text on near-black badge
            Orange = Themes.Orange.BG,    -- dark bg on orange badge
        }
        -- Inactive outline: each card's own border color
        local cardInactiveOutline = {
            Cynnet = Themes.Cynnet.BorderDim,
            Dark   = Themes.Dark.BorderDim,
            Light  = Themes.Light.Border,
            Orange = Themes.Orange.BorderDim,
        }

        local themeCardRefs = {}

        for _, tn in ipairs(themeNames) do
            local cardBG     = cardPreviewBG[tn]
            local cardText   = cardPreviewText[tn]
            local accentCol  = themeColors[tn]
            local inactiveOutline = cardInactiveOutline[tn]
            local isActive   = (tn == activeThemeName)

            local card = Frame({
                BackgroundColor3 = cardBG,
                Size = UDim2.new(1,0,0,58),
                Parent = themeGrid,
            })
            Round(card, 9)
            -- Stroke: active = accent color thick, inactive = card's own border
            local str = Instance.new("UIStroke")
            str.Color     = isActive and accentCol or inactiveOutline
            str.Thickness = isActive and 2 or 1
            str.Parent    = card

            -- Accent dot
            local dot = Frame({
                Size = UDim2.new(0,12,0,12),
                Position = UDim2.new(0,12,0.5,-6),
                AnchorPoint = Vector2.new(0,0.5),
                BackgroundColor3 = accentCol,
                Parent = card,
            })
            Round(dot,6)

            -- Theme name
            local tname = Instance.new("TextLabel")
            tname.Text = tn
            tname.Font = Enum.Font.GothamBold
            tname.TextSize = 13
            tname.TextColor3 = cardText
            tname.BackgroundTransparency = 1
            tname.TextXAlignment = Enum.TextXAlignment.Left
            tname.Size = UDim2.new(1,-30,1,0)
            tname.Position = UDim2.new(0,32,0,0)
            tname.Parent = card

            -- Active badge (uses the card's own accent + contrasting text)
            local activeBadge = Frame({
                Size = UDim2.new(0,0,0,16), AutomaticSize = Enum.AutomaticSize.X,
                Position = UDim2.new(1,-4,0,6), AnchorPoint = Vector2.new(1,0),
                BackgroundColor3 = accentCol, Parent = card,
            })
            Round(activeBadge,8); Pad(activeBadge,0,0,7,7)
            local badgeLbl = Instance.new("TextLabel")
            badgeLbl.Text = "active"
            badgeLbl.Font = Enum.Font.GothamBold
            badgeLbl.TextSize = 9
            badgeLbl.TextColor3 = cardBadgeText[tn]
            badgeLbl.BackgroundTransparency = 1
            badgeLbl.Size = UDim2.new(1,0,1,0)
            badgeLbl.Parent = activeBadge
            activeBadge.Visible = isActive

            themeCardRefs[tn] = { card=card, stroke=str, badge=activeBadge, bg=cardBG, text=cardText }

            local clickBtn = Instance.new("TextButton")
            clickBtn.Size = UDim2.new(1,0,1,0); clickBtn.Text = ""
            clickBtn.BackgroundTransparency = 1; clickBtn.ZIndex = 5; clickBtn.Parent = card

            clickBtn.MouseEnter:Connect(function()
                if tn ~= activeThemeName then
                    -- Slightly lighten/darken the card on hover
                    local bg = cardBG
                    local r = math.min(bg.R + 0.06, 1)
                    local g = math.min(bg.G + 0.06, 1)
                    local b2 = math.min(bg.B + 0.06, 1)
                    Tw(card, {BackgroundColor3 = Color3.new(r,g,b2)}, TI.Fast)
                end
            end)
            clickBtn.MouseLeave:Connect(function()
                if tn ~= activeThemeName then Tw(card, {BackgroundColor3 = cardBG}, TI.Fast) end
            end)
            clickBtn.MouseButton1Click:Connect(function()
                if tn == activeThemeName then return end
                -- Deactivate old card
                local old = themeCardRefs[activeThemeName]
                if old then
                    old.stroke.Color     = cardInactiveOutline[activeThemeName]
                    old.stroke.Thickness = 1
                    old.badge.Visible    = false
                end
                activeThemeName = tn
                -- Activate this card
                str.Color     = accentCol
                str.Thickness = 2
                activeBadge.Visible = true
                -- Apply theme to everything else
                ApplyTheme(tn)
            end)
        end

        return tab
    end

    -- ──────────────────────────────────────────────
    --  Notify
    -- ──────────────────────────────────────────────
    function WindowObj:Notify(cfg)
        cfg=cfg or {}
        local col=cfg.Color or T.Accent
        local toast=Frame({Size=UDim2.new(0,280,0,0),Position=UDim2.new(1,20,1,-20),
            AnchorPoint=Vector2.new(0,1),BackgroundColor3=T.Surface,
            AutomaticSize=Enum.AutomaticSize.Y,ClipsDescendants=true,ZIndex=50,Parent=ScreenGui})
        Round(toast,10); Stroke(toast,col,1)
        Frame({Size=UDim2.new(0,3,1,0),BackgroundColor3=col,Parent=toast})
        Pad(toast,10,10,14,14)
        Label({Text=cfg.Message or "Notification",Font=Enum.Font.Gotham,TextSize=12,TextColor3=T.TextPrimary,TextWrapped=true,AutomaticSize=Enum.AutomaticSize.Y,Size=UDim2.new(1,-8,0,0),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=51,Parent=toast})
        Tw(toast,{Position=UDim2.new(1,-300,1,-20)},TI.Med)
        task.delay(cfg.Duration or 3,function()
            Tw(toast,{Position=UDim2.new(1,20,1,-20)},TI.Med)
            task.delay(0.35,function() toast:Destroy() end)
        end)
    end

    -- ──────────────────────────────────────────────
    --  Insert key toggle  (with smooth animation)
    -- ──────────────────────────────────────────────
    UserInputService.InputBegan:Connect(function(inp, gpe)
        if gpe then return end
        if inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == CurrentKey then
            UIVisible = not UIVisible
            if UIVisible then
                Win.Visible = true
                Tw(Win, {BackgroundTransparency=0, Size=UDim2.new(0,WinSize.X,0,minimised and 52 or WinSize.Y)}, TI.Spring)
            else
                Tw(Win, {BackgroundTransparency=1, Size=UDim2.new(0,WinSize.X,0,0)}, TI.Med)
                task.delay(0.32, function() if not UIVisible then Win.Visible = false end end)
            end
        end
    end)

    -- Play intro → open window → spawn watermark → create settings tab
    task.spawn(function()
        PlayIntro(function()
            task.wait(0.08)
            Win.BackgroundTransparency = 1
            Win.Size = UDim2.new(0,WinSize.X,0,0)
            Tw(Win,{BackgroundTransparency=0},TI.Med)
            Tw(Win,{Size=UDim2.new(0,WinSize.X,0,WinSize.Y)},TI.Spring)
            task.wait(0.25)
            CreateWatermark(ScreenGui)
            CreateSettingsTab()
        end)
    end)

    return WindowObj
end

return Library
